# Get your free Mapbox token at https://mapbox.com
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Optional: Spotify integration to pause music during directions
# NOTE: Requires Spotify Premium - free accounts cannot control playback
# Create an app at https://developer.spotify.com/dashboard
# Add your redirect URI (e.g., http://localhost:5173/) to the app settings
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
# Optional: Override redirect URI (defaults to window.location.origin)
# VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173/
